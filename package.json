{
  "name": "lostsouls-game",
  "private": true,
  "version": "0.8.3",
  "type": "module",
  "description": "A 3D bullet-hell twin-stick shooter with co-op, procedural systems, deterministic tests, and production smoke checks.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "lint": "eslint src server.js",
    "format": "prettier --write \"**/*.{js,mjs,html,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,html,css,json,md}\"",
    "test": "vitest run",
    "test:proof": "vitest run tests/input.proof.test.js tests/progression.proof.test.js tests/droprate.proof.test.js tests/assets.proof.test.js",
    "test:coverage": "vitest run --coverage",
    "smoke:browser": "node scripts/browser-smoke.mjs",
    "smoke:prod": "node scripts/prod-health-proof.mjs",
    "audio:report": "node scripts/audio-studio.mjs report",
    "audio:process": "node scripts/audio-studio.mjs process",
    "render:studio": "node scripts/render-studio.mjs",
    "audit": "node scripts/audit-drift.mjs"
  },
  "dependencies": {
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "howler": "^2.2.4",
    "lil-gui": "^0.21.0",
    "n8ao": "^1.10.2",
    "postprocessing": "^6.39.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-security": "^4.0.1",
    "globals": "^17.6.0",
    "playwright": "^1.61.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.4.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
