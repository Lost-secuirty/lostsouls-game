#!/bin/sh
# Pre-commit secret/PII gate for this repo.
#
# Activate once per clone:   git config core.hooksPath .githooks
# Intentional one-off bypass: git commit --no-verify   (use sparingly)
#
# Blocks the commit (exit 1) if staged content looks like a secret or PII.
# See tools/scan_staged.py and AGENTS.md.

# Run Python in UTF-8 mode so it decodes git's UTF-8 output regardless of the OS
# locale. Without this, Windows defaults to cp1252 and the scanner crashes on any
# emoji/unicode in a diff (CI is fine — Linux already defaults to UTF-8).
export PYTHONUTF8=1

root=$(git rev-parse --show-toplevel)
if [ "$#" -gt 0 ]; then
  script=$1
  shift
else
  # Normal commit path. Auto-format staged files with Prettier and re-stage them,
  # so CI's `format:check` never fails on style (saves a push/fix/re-push round-trip).
  # Caveat: re-staging restages the whole file, so avoid partial (`git add -p`) staging
  # of a file you don't want fully committed. Skips silently if npx/Prettier is absent.
  if command -v npx >/dev/null 2>&1; then
    fmt_files=$(git diff --cached --name-only --diff-filter=ACM -- \
      '*.js' '*.mjs' '*.html' '*.css' '*.json' '*.md')
    if [ -n "$fmt_files" ]; then
      printf '%s\n' "$fmt_files" | xargs npx prettier --write && \
        printf '%s\n' "$fmt_files" | xargs git add
    fi
  fi
  script=tools/scan_staged.py
  set -- --staged
fi

case "$script" in
/*) ;;
*) script="$root/$script" ;;
esac

if command -v python3 >/dev/null 2>&1; then
  exec python3 "$script" "$@"
elif command -v python >/dev/null 2>&1; then
  exec python "$script" "$@"
elif command -v py >/dev/null 2>&1; then
  exec py -3 "$script" "$@"
fi

echo "pre-commit: no Python 3 interpreter found; secret/PII gate cannot run." >&2
exit 1
